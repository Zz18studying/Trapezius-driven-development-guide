<!-- pages/route/route.wxml -->
<view class="container">
  <view class="header">
    <text class="title">选择您的兴趣</text>
    <text class="subtitle">AI将为您推荐专属游览路线</text>
  </view>

  <!-- 兴趣选项 -->
  <view class="interests">
    <view 
      class="interest-item {{selectedInterest === 'history' ? 'active' : ''}}"
      bindtap="selectInterest"
      data-interest="history"
    >
      <text class="icon">🏛️</text>
      <text>历史文化</text>
    </view>
    <view 
      class="interest-item {{selectedInterest === 'nature' ? 'active' : ''}}"
      bindtap="selectInterest"
      data-interest="nature"
    >
      <text class="icon">🌿</text>
      <text>自然风光</text>
    </view>
    <view 
      class="interest-item {{selectedInterest === 'family' ? 'active' : ''}}"
      bindtap="selectInterest"
      data-interest="family"
    >
      <text class="icon">👨‍👩‍👧</text>
      <text>亲子家庭</text>
    </view>
  </view>

  <!-- 路线详情 -->
  <view class="route-detail" wx:if="{{currentRoute}}">
    <view class="route-header">
      <text class="route-name">{{currentRoute.name}}</text>
      <text class="route-duration">⏱️ {{currentRoute.duration}}</text>
    </view>
    <text class="route-desc">{{currentRoute.description}}</text>
    
    <view class="spots">
      <text class="spots-title">📍 途经景点</text>
      <view class="spot-list">
        <view class="spot-item" wx:for="{{currentRoute.spots}}" wx:key="index">
          <text class="spot-num">{{index + 1}}</text>
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <button class="btn-ask" bindtap="askAboutRoute">向AI导游咨询详情</button>
  </view>
</view>