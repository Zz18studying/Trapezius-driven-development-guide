/* app.wxss - 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.btn-primary {
  background: linear-gradient(135deg, #4a6741 0%, #6b8c5c 100%);
  color: white;
  border-radius: 40px;
  padding: 12px 24px;
  font-size: 28rpx;
}